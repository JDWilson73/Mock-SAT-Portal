# ── Database (Neon) ───────────────────────────────────────────────────────────
# Found in Neon dashboard → your project → Connection string
# Use the "Pooled connection" string for production (ends in ?sslmode=require)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-64-byte-random-hex"
JWT_REFRESH_SECRET="replace-with-a-different-64-byte-random-hex"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── CORS ─────────────────────────────────────────────────────────────────────
# Local dev: http://localhost:5173
# Production: your Vercel deployment URL, e.g. https://sat-portal.vercel.app
CLIENT_ORIGIN="http://localhost:5173"

# ── Vercel (set automatically in Vercel's runtime — do not set manually) ──────
# VERCEL=1
